# banquito-switch-billing-service environment example
SERVER_PORT=8084

DB_URL=jdbc:postgresql://postgres:5432/SWITCH_COMISIONES_DB
DB_USERNAME=postgres
DB_PASSWORD=postgres

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

RABBIT_EXCHANGE_BILLING=switch.billing.exchange
RABBIT_EXCHANGE_REPORTING=switch.reporting.exchange
RABBIT_QUEUE_BILLING_BATCH_COMPLETED=switch.billing.batch-completed.queue
RABBIT_QUEUE_REPORTING_BILLING_COMPLETED=switch.reporting.billing-completed.queue
RABBIT_ROUTING_KEY_BATCH_LINES_COMPLETED=batch.lines.completed
RABBIT_ROUTING_KEY_BILLING_COMPLETED=billing.completed

SWITCH_BILLING_UNIT_FEE=0.40
SWITCH_BILLING_FALLBACK_COMPANY_RUC=1790012345001
SWITCH_BILLING_FALLBACK_SOURCE_ACCOUNT_NUMBER=2200012345

# Deprecated legacy Core gRPC settings
CORE_GRPC_HOST=core-banking-mock
CORE_GRPC_PORT=9090
CORE_GRPC_DEADLINE_MS=60000

# Core REST via Kong/API Manager
CORE_KONG_BASE_URL=http://localhost:8000
CORE_KONG_SWITCH_CORE_PATH=/api/v1/switch-core
CORE_KONG_PAYMENT_RESERVATIONS_PATH=/payment-reservations
CORE_KONG_AUTH_TOKEN=
CORE_KONG_CLIENT_TOKEN_ENABLED=true
CORE_KONG_CLIENT_ID=switch-pagos-internos-service
CORE_KONG_CLIENT_SECRET=
CORE_KONG_SERVICE_FEE_REQUIRED_SCOPE=core.reserve.fee
CORE_KONG_CLIENT_TOKEN_PATH=/api/v1/auth/client-token
CORE_KONG_CLIENT_TOKEN_REFRESH_SKEW_SECONDS=60
CORE_KONG_CONNECT_TIMEOUT_MS=5000
CORE_KONG_READ_TIMEOUT_MS=30000
